generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Branch {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businessCenters BusinessCenter[]
  users           User[]
}

model BusinessCenter {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branchId String
  branch   Branch         @relation(fields: [branchId], references: [id])
  stores   StoreProject[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("SURVEY_STAFF")
  region    String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  assignedStores StoreProject[] @relation("PMStores")
  assignedTasks  Task[]         @relation("TaskAssignee")
  activities     Activity[]
  issues         Issue[]        @relation("IssueReporter")
  phaseNotes     PhaseNote[]    @relation("PhaseNoteAuthor")
  baselines      PhaseBaseline[] @relation("BaselineCreator")
}

model StoreProject {
  id             String    @id @default(cuid())
  name           String
  code           String    @unique
  address        String
  region         String?
  targetOpenDate DateTime?
  actualOpenDate DateTime?
  status         String    @default("PLANNING")
  progress       Int       @default(0)
  budget         Float?
  notes          String?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  pmId             String?
  pm               User?           @relation("PMStores", fields: [pmId], references: [id])
  businessCenterId String?
  bc               BusinessCenter? @relation(fields: [businessCenterId], references: [id])
  phases           Phase[]
  issues           Issue[]
  activities       Activity[]
  baselines        PhaseBaseline[]
}

model Phase {
  id          String    @id @default(cuid())
  phaseNumber Int
  name        String
  description String?
  status      String    @default("NOT_STARTED")
  plannedStart DateTime?
  plannedEnd  DateTime?
  actualStart DateTime?
  actualEnd   DateTime?
  order       Int

  storeId String
  store   StoreProject @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tasks   Task[]
  notes   PhaseNote[]

  @@unique([storeId, phaseNumber])
}

// Quick text notes attached to a specific phase (for daily logging like
// "rain delayed construction 3 days", "vendor late on delivery").
// Lighter than Issues — no severity/status workflow, just text + author + date.
model PhaseNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phaseId   String
  phase     Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation("PhaseNoteAuthor", fields: [authorId], references: [id])
}

// Snapshot đông cứng plannedStart/plannedEnd của tất cả 11 phase tại 1 thời điểm,
// để đối chiếu sau này ("Trễ 12 ngày so với Kế hoạch ban đầu").
model PhaseBaseline {
  id        String   @id @default(cuid())
  name      String                                            // "Kế hoạch ban đầu", "Sau ký HĐ"
  createdAt DateTime @default(now())

  storeId   String
  store     StoreProject @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy String?
  creator   User?        @relation("BaselineCreator", fields: [createdBy], references: [id])
  snapshots PhaseBaselineSnapshot[]
}

model PhaseBaselineSnapshot {
  id           String    @id @default(cuid())
  phaseNumber  Int                                            // 1..11
  plannedStart DateTime?
  plannedEnd   DateTime?

  baselineId String
  baseline   PhaseBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)

  @@unique([baselineId, phaseNumber])
}

// Cấu hình mẫu cho 11 giai đoạn — admin có thể chỉnh độ dài + tên mặc định
// 11 records cố định, mỗi record cho 1 phaseNumber 1..11
model PhaseTemplate {
  phaseNumber  Int      @id          // 1..11
  name         String
  description  String?
  durationDays Int                   // độ dài mặc định (ngày)
  taskTitles   String                // JSON-encoded string[] — danh sách task mặc định
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  phaseId    String
  phase      Phase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
}

model Issue {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("ISSUE")
  severity    String   @default("MEDIUM")
  status      String   @default("OPEN")
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storeId    String
  store      StoreProject @relation(fields: [storeId], references: [id], onDelete: Cascade)
  reporterId String?
  reporter   User?        @relation("IssueReporter", fields: [reporterId], references: [id])
}

model Activity {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())

  userId  String?
  user    User?        @relation(fields: [userId], references: [id])
  storeId String?
  store   StoreProject? @relation(fields: [storeId], references: [id])
}
