# ==============================
# TELECOM STORE MANAGER — ENV
# ==============================
# Copy file này thành .env và điền giá trị thực

# Database (SQLite local — file path)
DATABASE_URL="file:./dev.db"

# NextAuth — đổi SECRET thành chuỗi random mạnh khi deploy production
# Tạo random key: openssl rand -base64 32
NEXTAUTH_SECRET="telecom-store-super-secret-key-2024-change-in-production"

# URL của app (đổi khi deploy)
NEXTAUTH_URL="http://localhost:3000"

# ==============================
# HƯỚNG DẪN SETUP (MÁY MỚI)
# ==============================
# 1. cp .env.example .env
# 2. npm install
# 3. npx prisma migrate dev
# 4. node prisma/seed.js
# 5. npm run dev
# → Mở http://localhost:3000
